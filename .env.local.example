# ===================================
# CONFIGURAÇÃO DO BANCO DE DADOS
# ===================================
# O sistema usa apenas uma opção por vez:
# - Supabase: requer NEXT_PUBLIC_SUPABASE_URL + NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY + SUPABASE_SECRET_KEY
# - MySQL: requer DATABASE_URL
# ===================================

# ===================================
# OPÇÃO 1: SUPABASE
# ===================================
# Preencha as variáveis abaixo para operar com Supabase/PostgreSQL.
# NEXT_PUBLIC_SUPABASE_URL="https://seu-projeto.supabase.co"
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="sb_publishable_..."
# SUPABASE_SECRET_KEY="sb_secret_..."

# ===================================
# OPÇÃO 2: MYSQL
# ===================================
# Preencha a variável abaixo para operar com MySQL.

# DATABASE_URL="mysql://usuario:senha@host:porta/nome_do_banco"
# Exemplo:
# DATABASE_URL="mysql://u123456789_admin:SuaSenha123@srv123.hostinger.com.br:3306/u123456789_compras"

# ===================================
# ACESSO AO SISTEMA
# ===================================
# Credenciais iniciais do usuário administrador.
# Se não forem definidas, o sistema cria automaticamente:
# APP_ADMIN_EMAIL="admin@compras.local"
# APP_ADMIN_PASSWORD="admin123456"

# AUTH_SECRET="gere-uma-chave-segura"
# APP_ADMIN_NAME="Administrador do Sistema"
# APP_ADMIN_EMAIL="admin@compras.local"
# APP_ADMIN_PASSWORD="admin123456"
